# ============================================================
# GramExpress — Environment Variables
# Copy this file to .env for local development
# Add these in Render dashboard for production
# ============================================================

# MongoDB Atlas Connection String
# Get from: MongoDB Atlas → Connect → Drivers → Copy connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/gramexpress?retryWrites=true&w=majority

# JWT Secret — change this to any random string in production
JWT_SECRET=gramexpress_secret_key_2026_change_me

# Port (Render sets this automatically)
PORT=3000

# Firebase Private Key (optional — for OTP)
# Paste your private key here if deploying separately
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
